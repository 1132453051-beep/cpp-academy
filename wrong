<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>错题本 · 编程鸭</title>
<link rel="stylesheet" href="assets/style.css">
<style>
.card { background:#fff; border-radius:16px; padding:20px; margin-bottom:16px; box-shadow:0 8px 30px rgba(0,0,0,.06); }
.meta { color:#666; font-size:13px; margin-top:6px; }
.empty { text-align:center; color:#888; padding:40px; }
</style>
</head>

<body>

<header>
    <h1>📕 错题本</h1>
    <a href="index.html">← 返回首页</a>
</header>

<main class="container" id="list"></main>

<script>
const list = document.getElementById("list");
const wrong = JSON.parse(localStorage.getItem("wrong") || "[]");

if (wrong.length === 0) {
    list.innerHTML = `<div class="empty">🦆 还没有错题，继续保持！</div>`;
} else {
    wrong.reverse().forEach(item => {
        const d = new Date(item.time);
        list.innerHTML += `
        <div class="card">
            <h3>${item.title}</h3>
            <div class="meta">
                题目编号：${item.id}<br>
                答错时间：${d.toLocaleString()}
            </div>
        </div>
        `;
    });
}
</script>

</body>
</html>
